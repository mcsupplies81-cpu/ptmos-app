{
  "expo": {
    "name": "PT-OS",
    "slug": "ptmos-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "ptmos",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#14172A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ptmos.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "PT-OS sends reminders for your protocol doses.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "PT-OS uses your photo library to set your profile picture."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#14172A"
      },
      "package": "com.ptmos.app",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e8b2b5e5-6000-47b1-be16-b615e62dfc2a"
      }
    },
    "owner": "mcsupplies"
  }
}
